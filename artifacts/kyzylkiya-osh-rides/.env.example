# Оставьте пустым, если фронт и API на одном домене (как на Railway с server.py).
VITE_API_BASE_URL=

# Вход / «регистрация» через Telegram: при сборке true включает экран входа до приложения.
VITE_AUTH_ENABLED=true

# Токен бота от @BotFather и username бота (без @). На сервере (Railway Variables) те же имена.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Опционально: ссылка на бота в шапке сайта, если не хотите зависеть только от server (при сборке).
# VITE_TELEGRAM_BOT_USERNAME=alaket_kg_bot

# Опционально: файл со списком залогинившихся пользователей (по умолчанию рядом с server.py).
# TELEGRAM_USERS_FILE=/data/telegram_users.json
